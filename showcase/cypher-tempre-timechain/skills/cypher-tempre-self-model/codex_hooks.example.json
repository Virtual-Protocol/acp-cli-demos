{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"__SKILL_DIR__/session_start_hook.sh\"",
            "timeout": 30,
            "statusMessage": "Loading Cypher Tempre self-model"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"__SKILL_DIR__/loop_hook.sh\"",
            "timeout": 30,
            "statusMessage": "Marking Cypher Tempre turn"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"__SKILL_DIR__/stop_hook.sh\"",
            "timeout": 30,
            "statusMessage": "Checking Cypher Tempre seal"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"__SKILL_DIR__/subagent_stop_hook.sh\"",
            "timeout": 30,
            "statusMessage": "Checking Cypher Tempre subagent seal"
          }
        ]
      }
    ]
  }
}
