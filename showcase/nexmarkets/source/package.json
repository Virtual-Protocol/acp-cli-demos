{
  "name": "nexmarkets-nexstudio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run db:generate && next build",
    "start": "next start",
    "smoke": "node scripts/smoke.mjs",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "grok:x": "tsx scripts/grok-x-account.ts",
    "workers:once": "tsx scripts/workers.ts",
    "workers:watch": "tsx scripts/workers.ts --watch",
    "typecheck": "npm run db:generate && tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run contracts:compile && npm run contracts:test",
    "db:schema:dev": "node scripts/generate-sqlite-schema.mjs",
    "db:generate:postgres": "prisma generate",
    "db:generate:sqlite": "npm run db:schema:dev && prisma generate --config prisma.dev.config.ts",
    "db:generate": "node scripts/clean-generated-prisma.mjs && npm run db:generate:postgres && npm run db:generate:sqlite",
    "db:dev:push": "npm run db:schema:dev && prisma db push --config prisma.dev.config.ts",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "contracts:compile": "cd contracts && hardhat compile",
    "contracts:test": "cd contracts && hardhat test nodejs test/NexMarkets.ts --no-compile",
    "contracts:coverage": "cd contracts && hardhat test nodejs test/NexMarkets.ts --coverage --no-compile",
    "contracts:deploy:testnet": "cd contracts && hardhat ignition deploy ignition/modules/NexMarkets.ts --network robinhoodTestnet",
    "hyperframes:check": "cd hyperframes/example && npx --yes hyperframes@0.7.56 check",
    "hyperframes:preview": "cd hyperframes/example && npx --yes hyperframes@0.7.56 preview",
    "hyperframes:render:cloud": "cd hyperframes/example && npx --yes hyperframes@0.7.56 cloud render --quality standard --fps 30",
    "dev:next": "next dev",
    "gemini:live": "node scripts/gemini-live-bridge.mjs"
  },
  "dependencies": {
    "@hyperframes/core": "0.7.56",
    "@hyperframes/player": "0.7.56",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.101.2",
    "dotenv": "17.4.2",
    "fflate": "0.8.2",
    "gsap": "3.14.2",
    "next": "16.2.10",
    "pg": "8.22.0",
    "playwright-core": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.1",
    "wagmi": "^3.7.1",
    "zod": "4.4.3",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@openzeppelin/contracts": "5.6.1",
    "@types/node": "26.1.1",
    "@types/pg": "8.15.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "hardhat": "3.9.1",
    "prisma": "7.8.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
