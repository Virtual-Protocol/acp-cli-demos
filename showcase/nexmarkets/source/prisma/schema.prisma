generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductionKind {
  VIDEO
  INFOGRAPHIC
}

enum ProductionStatus {
  DRAFT
  SOURCE_PENDING
  SOURCE_READY
  DIRECTION_READY
  AWAITING_PAYMENT
  PAYMENT_PENDING
  PAID
  LIVE_SESSION_READY
  LIVE_SESSION_ACTIVE
  BRIEF_REVIEW
  STORYBOARD_REVIEW
  QUEUED
  REVIEWING_SOURCE
  BUILDING_STORY
  PRODUCING_SCENES
  ADDING_AUDIO
  RENDERING
  VERSION_READY
  REVISION_REQUESTED
  APPROVED
  FAILED
  CANCELLED
  REFUNDED
}

enum SourceKind {
  WEBSITE
  TEXT
  FILE
  X_POST
  MARKETPLACE
  PROJECT_SOURCE
}

enum SourceStatus {
  PENDING
  ANALYSING
  READY
  BLOCKED
  FAILED
}

enum PaymentStatus {
  CREATED
  SUBMITTED
  CONFIRMING
  CONFIRMED
  FAILED
  EXPIRED
  SETTLED
  REFUNDED
  ORPHANED
}

enum RenderStatus {
  QUEUED
  UPLOADING
  RENDERING
  DOWNLOADING
  CHECKING
  COMPLETED
  FAILED
  CANCELLED
}

enum ReputationStatus {
  NOT_CONNECTED
  X_CONNECTED
  ANALYSING
  BASE_CARD_READY
  ENHANCEMENT_ELIGIBLE
  LIVE_ACTIVE
  PROFILE_REVIEW
  ENHANCED_CARD_READY
  PAUSED
}

enum ListingType {
  TASK
  SERVICE
  ROLE
  CAMPAIGN
  DIRECT_HIRE
}

enum ListingStatus {
  DRAFT
  FUNDING
  OPEN
  PAUSED
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  SUBMITTED
  SHORTLISTED
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum WorkroomStatus {
  FUNDED
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  REVISION_REQUESTED
  APPROVED
  RELEASED
  DISPUTED
  CANCELLED
  REFUNDED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum WorkspaceType {
  HUMAN
  PROJECT
  AGENT
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  AGENT
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DeliveryStatus {
  SUBMITTED
  REVISION_REQUESTED
  APPROVED
  WITHDRAWN
}

enum DisputeStatus {
  OPEN
  RESOLVED
  CANCELLED
}

model User {
  id                     String               @id @default(uuid()) @db.Uuid
  email                  String?              @unique
  handle                 String?              @unique
  displayName            String?
  avatarUrl              String?
  bio                    String?
  location               String?
  theme                  String               @default("dark")
  settings               Json                 @default("{}")
  lastSeenAt             DateTime?
  deletedAt              DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  sessions               Session[]
  authChallenges         AuthChallenge[]
  wallets                Wallet[]
  xAccounts              XAccount[]
  telegramConnections    TelegramConnection[]
  ownedWorkspaces        Workspace[]          @relation("WorkspaceOwner")
  workspaceMemberships   WorkspaceMembership[]
  sources                Source[]
  drafts                 Draft[]
  productions            Production[]         @relation("ProductionOwner")
  sessionProductions     Production[]         @relation("ProductionParticipant")
  approvedProductions    Production[]         @relation("ProductionApprover")
  liveSessions           LiveSession[]
  paymentIntents         PaymentIntent[]
  reputationProfiles     ReputationProfile[]
  ownedListings          Listing[]            @relation("ListingOwner")
  invitedListings        Listing[]            @relation("ListingInvitee")
  serviceRequests        ServiceRequest[]     @relation("ServiceRequestBuyer")
  applications           Application[]
  foundedWorkrooms       Workroom[]           @relation("WorkroomFounder")
  workerWorkrooms        Workroom[]           @relation("WorkroomWorker")
  workroomMessages       WorkroomMessage[]
  workroomDeliveries     WorkroomDelivery[]
  workroomRevisions      WorkroomRevision[]
  openedDisputes         WorkroomDispute[]     @relation("DisputeOpenedBy")
  resolvedDisputes       WorkroomDispute[]     @relation("DisputeResolvedBy")
  approvals              Approval[]
  notifications          Notification[]
  auditEvents            AuditEvent[]

  @@map("users")
}

model Session {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @db.Uuid
  tokenHash  String        @unique
  status     SessionStatus @default(ACTIVE)
  userAgent  String?
  ipHash     String?
  expiresAt  DateTime
  lastSeenAt DateTime      @default(now())
  revokedAt  DateTime?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@map("sessions")
}

model AuthChallenge {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @db.Uuid
  purpose     String
  identifier  String
  secretHash  String
  payload     Json      @default("{}")
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([purpose, identifier, expiresAt])
  @@map("auth_challenges")
}

model Workspace {
  id          String                @id @default(uuid()) @db.Uuid
  ownerUserId String                @db.Uuid
  slug        String                @unique
  name        String
  type        WorkspaceType
  avatarUrl   String?
  settings    Json                  @default("{}")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  owner       User                  @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  memberships WorkspaceMembership[]
  sources     Source[]
  productions Production[]
  listings    Listing[]

  @@index([ownerUserId, type])
  @@map("workspaces")
}

model WorkspaceMembership {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, role])
  @@map("workspace_memberships")
}

model Wallet {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  address    String
  chainId    Int
  verifiedAt DateTime
  isPrimary  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([address, chainId])
  @@index([userId, isPrimary])
  @@map("wallets")
}

model XAccount {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @db.Uuid
  providerUserId        String    @unique
  handle                String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  scopes                Json
  connectedAt           DateTime  @default(now())
  revokedAt             DateTime?
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("x_accounts")
}

model TelegramConnection {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  chatIdEncrypted String
  username        String?
  verifiedAt      DateTime
  revokedAt       DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("telegram_connections")
}

model Source {
  id               String       @id @default(uuid()) @db.Uuid
  ownerUserId      String       @db.Uuid
  workspaceId      String?      @db.Uuid
  name             String?
  kind             SourceKind
  originalUrl      String?
  objectKey        String?
  mimeType         String?
  sizeBytes        BigInt?
  isReusable       Boolean      @default(false)
  rawTextEncrypted String?
  extracted        Json?
  rights           Json         @default("{}")
  contentHash      String
  status           SourceStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  owner            User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  workspace        Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  productions      Production[]

  @@index([ownerUserId, status])
  @@index([workspaceId, isReusable])
  @@map("sources")
}

model Draft {
  id          String         @id @default(uuid()) @db.Uuid
  ownerUserId String         @db.Uuid
  workspaceId String?        @db.Uuid
  kind        ProductionKind
  title       String
  payload     Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  owner       User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, updatedAt])
  @@map("drafts")
}

model Production {
  id                       String              @id @default(uuid()) @db.Uuid
  ownerUserId              String              @db.Uuid
  workspaceId              String?             @db.Uuid
  kind                     ProductionKind
  title                    String
  status                   ProductionStatus    @default(DRAFT)
  sourceId                 String?             @db.Uuid
  payerWallet              String?
  sessionParticipantUserId String?             @db.Uuid
  approverUserId           String?             @db.Uuid
  direction                Json                @default("{}")
  brief                    Json?
  priceAtomic              BigInt?
  currentVersionId         String?             @unique @db.Uuid
  failureCode              String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  owner                    User                @relation("ProductionOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  workspace                Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  source                   Source?             @relation(fields: [sourceId], references: [id])
  sessionParticipant       User?               @relation("ProductionParticipant", fields: [sessionParticipantUserId], references: [id])
  approver                 User?               @relation("ProductionApprover", fields: [approverUserId], references: [id])
  currentVersion           ProductionVersion?  @relation("CurrentProductionVersion", fields: [currentVersionId], references: [id])
  versions                 ProductionVersion[] @relation("ProductionVersions")
  liveSessions             LiveSession[]
  paymentIntents           PaymentIntent[]
  quotes                   Quote[]
  renderJobs               RenderJob[]
  approvals                Approval[]

  @@index([ownerUserId, status])
  @@index([status, updatedAt])
  @@map("productions")
}

model ProductionVersion {
  id                   String      @id @default(uuid()) @db.Uuid
  productionId         String      @db.Uuid
  versionNumber        Int
  compositionObjectKey String?
  previewObjectKey     String?
  outputObjectKey      String?
  thumbnailObjectKey   String?
  manifest             Json
  sourceHash           String
  approvedAt           DateTime?
  createdAt            DateTime    @default(now())
  production           Production  @relation("ProductionVersions", fields: [productionId], references: [id], onDelete: Cascade)
  currentFor           Production? @relation("CurrentProductionVersion")
  approvals            Approval[]

  @@unique([productionId, versionNumber])
  @@map("production_versions")
}

model LiveSession {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  purpose             String
  productionId        String?   @db.Uuid
  reputationProfileId String?   @db.Uuid
  state               String
  transcriptObjectKey String?
  context             Json      @default("{}")
  paymentReference    String?
  startedAt           DateTime?
  endedAt             DateTime?
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  production          Production? @relation(fields: [productionId], references: [id], onDelete: SetNull)
  messages            LiveSessionMessage[]

  @@index([productionId, state])
  @@map("live_sessions")
}

model LiveSessionMessage {
  id         String      @id @default(uuid()) @db.Uuid
  sessionId  String      @db.Uuid
  sequence   Int
  speaker    String
  text       String
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now())
  session    LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@map("live_session_messages")
}

model Quote {
  id                       String     @id @default(uuid()) @db.Uuid
  productionId             String     @db.Uuid
  payer                    String
  standardPriceAtomic      BigInt
  discountAtomic           BigInt
  finalPriceAtomic         BigInt
  nexBalanceAtomic         BigInt
  nexThresholdAtomic       BigInt
  payerBalanceAtomic       BigInt
  eligible                 Boolean
  pricingRuleVersion       String
  chainConfigVersion       BigInt
  expiresAt                DateTime
  createdAt                DateTime   @default(now())
  production               Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId, expiresAt])
  @@map("quotes")
}

model PaymentIntent {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  productionId      String?       @db.Uuid
  purpose           String
  referenceId       String        @db.Uuid
  payer             String
  token             String
  amountAtomic      BigInt
  chainId           Int
  quoteExpiresAt    DateTime
  txHash            String?
  contractPaymentId String?
  status            PaymentStatus @default(CREATED)
  idempotencyKey    String        @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  production        Production?   @relation(fields: [productionId], references: [id], onDelete: SetNull)

  @@index([txHash])
  @@map("payment_intents")
}

model RenderJob {
  id                String       @id @default(uuid()) @db.Uuid
  productionId      String       @db.Uuid
  provider          String
  providerJobId     String?      @unique
  providerAssetId   String?
  compositionHash   String
  idempotencyKey    String       @unique
  status            RenderStatus @default(QUEUED)
  outputUrl          String?
  outputObjectKey   String?
  errorCode          String?
  callbackId         String       @unique
  request            Json
  response           Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  production        Production   @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId, status])
  @@map("render_jobs")
}

model Approval {
  id             String              @id @default(uuid()) @db.Uuid
  userId         String              @db.Uuid
  productionId   String?             @db.Uuid
  versionId      String?             @db.Uuid
  artifactType   String
  artifactId     String
  artifactHash   String
  decision       ApprovalDecision
  note           String?
  createdAt      DateTime            @default(now())
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  production     Production?         @relation(fields: [productionId], references: [id], onDelete: Cascade)
  version        ProductionVersion?  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([artifactType, artifactId])
  @@map("approvals")
}

model ReputationProfile {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @db.Uuid
  handle             String
  status             ReputationStatus @default(NOT_CONNECTED)
  baseProfile        Json             @default("{}")
  enhancedProfile    Json?
  publicSettings     Json             @default("{}")
  publicSlug         String           @unique
  currentCardVersion Int              @default(1)
  lastXRefreshAt     DateTime?
  pausedAt           DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidence           ReputationEvidence[]

  @@index([userId, status])
  @@map("reputation_profiles")
}

model ReputationEvidence {
  id         String             @id @default(uuid()) @db.Uuid
  profileId  String             @db.Uuid
  sourceType String
  sourceUrl  String?
  sourceDate DateTime?
  excerpt    String?
  supports   Json
  visibility String             @default("PUBLIC")
  confidence Int
  status     String
  profile    ReputationProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@map("reputation_evidence")
}

model Listing {
  id           String        @id @default(uuid()) @db.Uuid
  ownerUserId  String        @db.Uuid
  invitedUserId String?      @db.Uuid
  workspaceId  String?       @db.Uuid
  slug         String        @unique
  type         ListingType
  title        String
  outcome      String
  detail       Json          @default("{}")
  budgetAtomic BigInt?
  deadline     DateTime?
  status       ListingStatus @default(DRAFT)
  funded       Boolean       @default(false)
  visibility   String        @default("PUBLIC")
  places       Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        User          @relation("ListingOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  invitedUser  User?         @relation("ListingInvitee", fields: [invitedUserId], references: [id], onDelete: SetNull)
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  applications Application[]
  workrooms     Workroom[]
  receivedServiceRequests ServiceRequest[] @relation("ServiceOffer")
  serviceRequest ServiceRequest? @relation("ServiceRequestListing")

  @@index([status, createdAt])
  @@index([type, status])
  @@index([invitedUserId, status])
  @@map("listings")
}

model Application {
  id                String            @id @default(uuid()) @db.Uuid
  listingId         String            @db.Uuid
  applicantUserId   String            @db.Uuid
  proposedFeeAtomic BigInt?
  response          String
  deliveryPlan      String?
  availability      String?
  evidenceIds       Json              @default("[]")
  status            ApplicationStatus @default(SUBMITTED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  listing           Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant         User              @relation(fields: [applicantUserId], references: [id], onDelete: Cascade)

  @@unique([listingId, applicantUserId])
  @@index([applicantUserId, status])
  @@map("applications")
}

model ServiceRequest {
  id               String   @id @default(uuid()) @db.Uuid
  serviceListingId String   @db.Uuid
  requestListingId String   @unique @db.Uuid
  buyerUserId      String   @db.Uuid
  message          String
  inputs           Json     @default("[]")
  status           String   @default("FUNDS_REQUIRED")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  serviceListing   Listing  @relation("ServiceOffer", fields: [serviceListingId], references: [id], onDelete: Restrict)
  requestListing   Listing  @relation("ServiceRequestListing", fields: [requestListingId], references: [id], onDelete: Cascade)
  buyer            User     @relation("ServiceRequestBuyer", fields: [buyerUserId], references: [id], onDelete: Cascade)

  @@index([serviceListingId, status])
  @@index([buyerUserId, status])
  @@map("service_requests")
}

model Workroom {
  id             String         @id @default(uuid()) @db.Uuid
  listingId      String         @db.Uuid
  founderUserId  String         @db.Uuid
  workerUserId   String         @db.Uuid
  status         WorkroomStatus @default(FUNDED)
  scope          Json           @default("{}")
  permissions    Json           @default("{}")
  escrowId       String?
  reviewDeadline DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  listing        Listing        @relation(fields: [listingId], references: [id])
  founder        User           @relation("WorkroomFounder", fields: [founderUserId], references: [id])
  worker         User           @relation("WorkroomWorker", fields: [workerUserId], references: [id])
  messages       WorkroomMessage[]
  deliveries     WorkroomDelivery[]
  revisions      WorkroomRevision[]
  disputes       WorkroomDispute[]

  @@index([founderUserId, status])
  @@index([workerUserId, status])
  @@map("workrooms")
}

model WorkroomMessage {
  id         String    @id @default(uuid()) @db.Uuid
  workroomId String    @db.Uuid
  authorId   String    @db.Uuid
  body       String
  attachments Json     @default("[]")
  createdAt  DateTime  @default(now())
  workroom   Workroom  @relation(fields: [workroomId], references: [id], onDelete: Cascade)
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workroomId, createdAt])
  @@map("workroom_messages")
}

model WorkroomDelivery {
  id            String         @id @default(uuid()) @db.Uuid
  workroomId    String         @db.Uuid
  submittedById String         @db.Uuid
  version       Int
  message       String
  objectKeys    Json           @default("[]")
  status        DeliveryStatus @default(SUBMITTED)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workroom      Workroom       @relation(fields: [workroomId], references: [id], onDelete: Cascade)
  submittedBy   User           @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  @@unique([workroomId, version])
  @@map("workroom_deliveries")
}

model WorkroomRevision {
  id          String    @id @default(uuid()) @db.Uuid
  workroomId  String    @db.Uuid
  requestedById String  @db.Uuid
  deliveryId  String?   @db.Uuid
  request     String
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  workroom    Workroom  @relation(fields: [workroomId], references: [id], onDelete: Cascade)
  requestedBy User      @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([workroomId, resolvedAt])
  @@map("workroom_revisions")
}

model WorkroomDispute {
  id           String        @id @default(uuid()) @db.Uuid
  workroomId   String        @db.Uuid
  openedById   String        @db.Uuid
  resolvedById String?       @db.Uuid
  reason       String
  evidence     Json          @default("[]")
  resolution   Json?
  status       DisputeStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  resolvedAt   DateTime?
  workroom     Workroom      @relation(fields: [workroomId], references: [id], onDelete: Cascade)
  openedBy     User          @relation("DisputeOpenedBy", fields: [openedById], references: [id], onDelete: Cascade)
  resolvedBy   User?         @relation("DisputeResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([workroomId, status])
  @@map("workroom_disputes")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  kind      String
  title     String
  body      String
  deepLink  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model NotificationOutbox {
  id             String    @id @default(uuid()) @db.Uuid
  destination    String
  dedupeKey      String    @unique
  payload        Json
  attempts       Int       @default(0)
  nextAttemptAt  DateTime  @default(now())
  deliveredAt    DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())

  @@index([deliveredAt, nextAttemptAt])
  @@map("notification_outbox")
}

model IdempotencyRecord {
  id          String   @id @default(uuid()) @db.Uuid
  scope       String
  key         String
  requestHash String
  statusCode  Int
  response    Json
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@unique([scope, key])
  @@index([expiresAt])
  @@map("idempotency_records")
}

model RateLimitBucket {
  id          String   @id @default(uuid()) @db.Uuid
  key         String
  category    String
  windowStart DateTime
  count       Int      @default(1)
  expiresAt   DateTime

  @@unique([key, category, windowStart])
  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

model ChainEvent {
  id              String   @id @default(uuid()) @db.Uuid
  chainId         Int
  contractAddress String
  blockNumber     BigInt
  blockHash       String
  transactionHash String
  logIndex        Int
  eventName       String
  opaqueId        String?
  payload         Json
  confirmedAt     DateTime?
  orphanedAt      DateTime?
  createdAt       DateTime @default(now())

  @@unique([chainId, transactionHash, logIndex])
  @@index([chainId, blockNumber])
  @@map("chain_events")
}

model AuditEvent {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  actorWallet String?
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  requestId   String
  ipHash      String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([requestId])
  @@map("audit_events")
}
