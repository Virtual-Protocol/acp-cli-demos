# Application
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
NEXMARKETS_DEV_SIMULATION=true
DATABASE_PROVIDER=sqlite
DEV_DATABASE_URL=file:./prisma/dev.db

# Prisma 7 + PostgreSQL production target. Set DATABASE_PROVIDER=postgresql and provide:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexmarkets?schema=public
DATABASE_URL=

# HyperFrames 0.7.56 + HeyGen managed cloud
HYPERFRAMES_VERSION=0.7.56
HYPERFRAMES_RENDER_PROVIDER=heygen_cloud
HEYGEN_API_URL=https://api.heygen.com
HEYGEN_API_KEY=
HEYGEN_HYPERFRAMES_CALLBACK_SECRET=
HEYGEN_HYPERFRAMES_CALLBACK_URL=http://localhost:3000/api/v1/webhooks/hyperframes

# Robinhood Chain
ROBINHOOD_NETWORK=testnet
ROBINHOOD_MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
ROBINHOOD_CONFIRMATIONS=3
USDC_ADDRESS=
NEX_TOKEN_ADDRESS=
NEX_DEX_CHAIN_ID=robinhood
NEX_BUY_URL=
ROBINHOOD_WALLET_RPC_URL=
ROBINHOOD_EXPLORER_URL=
ROBINHOOD_BRIDGE_URL=
NEX_PRICING_REGISTRY_ADDRESS=
NEX_PRODUCTION_PAYMENTS_ADDRESS=
NEX_WORK_ESCROW_ADDRESS=
DEPLOYER_PRIVATE_KEY=
ADMIN_ADDRESS=
OPERATOR_ADDRESS=
DISPUTE_RESOLVER_ADDRESS=
TREASURY_ADDRESS=

# X OAuth 2.0 (PKCE) and encrypted provider credentials
X_CLIENT_ID=
X_CLIENT_SECRET=
NEX_ENCRYPTION_KEY=

# NexMind provider (OpenAI-compatible chat endpoint owned by NexMarkets)
NEXMIND_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
NEXMIND_API_KEY=
# Optional aliases also accepted for Gemini credentials:
GEMINI_API_KEY=
GOOGLE_API_KEY=
NEXMIND_MODEL=gemini-2.0-flash

# Native Gemini Live for NexMind voice sessions. npm run dev starts the bridge.
GEMINI_LIVE_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
GEMINI_LIVE_VOICE=Puck
NEXMIND_LIVE_BRIDGE_PORT=8787
NEXT_PUBLIC_NEXMIND_LIVE_BRIDGE_PORT=8787
NEXT_PUBLIC_NEXMIND_LIVE_BRIDGE_URL=

# Email magic-link authentication (Resend)
RESEND_API_KEY=
EMAIL_FROM=NexMarkets <access@nexmarkets.example>

# Notifications and storage
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
OBJECT_STORAGE_LOCAL_ROOT=data/uploads
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=nexmarkets
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_SESSION_TOKEN=
MALWARE_SCAN_URL=
MALWARE_SCAN_KEY=
CHROMIUM_EXECUTABLE_PATH=
